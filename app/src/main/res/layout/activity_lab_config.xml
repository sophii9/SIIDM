<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1A237E"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── SECCIÓN BLUETOOTH ───────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Conexión Arduino (HC-05)"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A237E"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tvBluetoothStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BT: No conectado"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConectarBluetooth"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Conectar a Arduino"
                        app:strokeColor="#1A237E"
                        app:strokeWidth="1dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    <!-- Controles manuales -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEncender"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="💡 Encender"
                            android:enabled="false"
                            android:backgroundTint="#4CAF50" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnApagar"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="🌑 Apagar"
                            android:enabled="false"
                            android:backgroundTint="#F44336" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SECCIÓN SENSOR PIR ─────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Configuración del Sensor PIR"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A237E"
                        android:layout_marginBottom="16dp" />

                    <!-- Sensibilidad -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Sensibilidad:"
                            android:textSize="14sp"
                            android:textColor="#333333" />

                        <TextView
                            android:id="@+id/tvSensibilidadValor"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:text="Media"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A237E"
                            android:gravity="end" />

                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekBarSensibilidad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="2"
                        android:progress="1"
                        android:layout_marginBottom="16dp" />

                    <!-- Tiempo de espera -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tiempo sin movimiento:"
                            android:textSize="14sp"
                            android:textColor="#333333" />

                        <TextView
                            android:id="@+id/tvTiempoValor"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:text="10 min"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A237E"
                            android:gravity="end" />

                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekBarTiempo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="59"
                        android:progress="9" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SECCIÓN HORARIOS ───────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Horario de Operación"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A237E"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hora de inicio"
                        android:textSize="13sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="4dp" />

                    <TimePicker
                        android:id="@+id/tpHoraInicio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:timePickerMode="spinner"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hora de fin"
                        android:textSize="13sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="4dp" />

                    <TimePicker
                        android:id="@+id/tpHoraFin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:timePickerMode="spinner" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── BOTONES GUARDAR E INFORME ─────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:text="Guardar Configuración"
                android:textSize="15sp"
                android:backgroundTint="#1A237E" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerInforme"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="📊 Ver Informe Semanal"
                android:textSize="15sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#1A237E" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>