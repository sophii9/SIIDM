<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Indicador de color (activo/inactivo) -->
        <View
            android:id="@+id/viewEstado"
            android:layout_width="8dp"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:background="@android:color/holo_green_light" />

        <!-- Nombre y descripción del laboratorio -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvLabNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Laboratorio 1"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1A237E" />

            <TextView
                android:id="@+id/tvLabDescripcion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Control de iluminación y sensores"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Estado textual + flecha -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activo"
                android:textSize="12sp"
                android:textColor="#4CAF50"
                android:layout_marginBottom="4dp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_next"
                android:contentDescription="Configurar"
                app:tint="#BBBBBB" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>